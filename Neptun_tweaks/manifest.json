{
  "manifest_version": 3,
  "name": "Neptun Tweaks",
  "version": "1.2.2",
  "description": "Custom tweaks for the Neptun dashboard.",
  "browser_specific_settings": {
    "gecko": {
      "id": "neptun-tweaks@toklampas",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage" 
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://neptun.bme.hu/hallgatoi/*"],
      "js": [
        "modules/headerImage.js",
        "modules/listExpander.js",
        "modules/homePageExpander.js",
        "modules/version.js",
        "modules/calendarButton.js",
        "main.js"
      ]
    }
  ]
}